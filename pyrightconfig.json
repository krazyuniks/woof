{
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    ".venv",
    "**/__pycache__",
    "**/.pytest_cache",
    ".woof"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic",
  "extraPaths": [
    "src"
  ],
  "reportMissingImports": "warning",
  "reportMissingModuleSource": "none"
}