{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woof.dev/schemas/agents.schema.json",
  "title": "woof runtime settings",
  "description": "Project-side runtime settings at .woof/agents.toml. Dispatch routing and run profiles live only in .woof/policy.toml; this file carries non-routing runtime knobs.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "timeouts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_minutes": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 30,
          "description": "Pre-terminal wall-clock ceiling, in minutes."
        },
        "idle_seconds": {
          "type": "number",
          "minimum": 0,
          "default": 600
        },
        "completion_grace_seconds": {
          "type": "number",
          "minimum": 0,
          "default": 60
        },
        "completion_tail_cap_seconds": {
          "type": "number",
          "minimum": 0,
          "default": 120
        }
      }
    },
    "review_valve": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "every_n_work_units": {
          "type": "integer",
          "minimum": 1,
          "default": 5,
          "description": "Open a review gate after every N successful work-unit commits."
        },
        "end_of_epic": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "max_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 262144
        },
        "redact_patterns": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "mcp_servers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/mcp_server" },
      "description": "Portable MCP server definitions available to future policy/profile consumers."
    }
  },
  "$defs": {
    "mcp_server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
