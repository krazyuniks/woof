{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woof.dev/schemas/jsonl-events.schema.json",
  "title": "woof JSONL event",
  "description": "One line of .woof/epics/E<N>/epic.jsonl (stage-level narrative) or .woof/epics/E<N>/dispatch.jsonl (subprocess events). Both streams share this schema; the event field discriminates. Per-event payload fields validate via the conditional rules in allOf. Cross-line invariants (subprocess_returned matches a prior subprocess_spawned by pid; gate_resolved follows gate_opened; status transitions are monotonic) are helper-enforced, not schema-enforced.",
  "type": "object",
  "additionalProperties": true,
  "required": ["event", "at"],
  "properties": {
    "event": {
      "type": "string",
      "enum": [
        "spark_created",
        "discovery_started",
        "discovery_synthesised",
        "definition_started",
        "definition_closed",
        "plan_generated",
        "plan_critiqued",
        "plan_gate_opened",
        "plan_gate_resolved",
        "story_started",
        "story_completed",
        "story_gate_opened",
        "story_gate_resolved",
        "review_gate_opened",
        "review_gate_resolved",
        "epic_completed",
        "subprocess_spawned",
        "subprocess_returned",
        "subprocess_killed",
        "preflight_run",
        "github_synced",
        "github_sync_conflict",
        "cartography_refreshed",
        "token_usage"
      ],
      "description": "Event kind. Stage events (epic.jsonl): spark_created, discovery_*, definition_*, plan_*, story_*, *_gate_*, epic_completed. Dispatch events (dispatch.jsonl): subprocess_*. Operational events (either): preflight_run, github_synced, github_sync_conflict, cartography_refreshed, token_usage."
    },
    "at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp the event occurred."
    },
    "epic_id": {
      "type": "integer",
      "minimum": 1,
      "description": "Epic this event belongs to (gh issue number)."
    },
    "story_id": {
      "type": "string",
      "pattern": "^S[1-9]\\d*$"
    },
    "role": {
      "type": "string",
      "enum": ["orchestrator", "planner", "story-executor", "critiquer", "gate-resolver"],
      "description": "Role from .woof/agents.toml under which a subprocess was dispatched."
    },
    "harness": {
      "type": "string",
      "enum": ["cld", "cod", "in-session"],
      "description": "Wrapper that spawned the subprocess (or in-session for orchestrator/gate-resolver)."
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "exit_code": {
      "type": "integer"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "signal": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "description": "Free-form reason. Used by subprocess_killed (timeout, manual_cancel, ...). Gate resolution events use the structured 'decision' field instead."
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "revise_epic_contract",
        "revise_plan",
        "revise_story_scope",
        "split_story",
        "abandon_story",
        "abandon_epic"
      ],
      "description": "Gate resolution decision. approve = proceed. revise_epic_contract = re-enter Stage 2. revise_plan = re-enter Stage 3. revise_story_scope = edit current story's paths or satisfies. split_story = replace one story with multiple. abandon_story = skip and continue. abandon_epic = mark incomplete + close gh issue with note."
    },
    "cc_session_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "CC session UUID. Cross-link into ~/.claude/projects/<slug>/<uuid>.jsonl."
    },
    "codex_audit_path": {
      "type": "string",
      "minLength": 1,
      "description": "Path under .woof/epics/E<N>/audit/ where Codex prompt+output+meta were tee'd."
    },
    "empty_diff": {
      "type": "boolean"
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "gate_type": {
      "type": "string",
      "enum": ["plan_gate", "story_gate", "review_gate"]
    },
    "triggered_by": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Mirrors gate.md.triggered_by[] when emitting *_gate_opened."
    },
    "tokens_in": {
      "type": "integer",
      "minimum": 0,
      "description": "Prompt tokens. Used by token_usage events and post-subprocess summaries."
    },
    "tokens_out": {
      "type": "integer",
      "minimum": 0,
      "description": "Completion tokens."
    },
    "cache_read_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cache_write_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "artefacts_loaded": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Paths of artefacts read into the prompt. Useful for token-budget post-mortems."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "event": { "const": "subprocess_spawned" } },
        "required": ["event"]
      },
      "then": { "required": ["role", "harness", "pid"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "subprocess_returned" } },
        "required": ["event"]
      },
      "then": { "required": ["pid", "exit_code", "duration_ms"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "subprocess_killed" } },
        "required": ["event"]
      },
      "then": { "required": ["pid", "signal", "reason"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "story_started" } },
        "required": ["event"]
      },
      "then": { "required": ["story_id"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "story_completed" } },
        "required": ["event"]
      },
      "then": { "required": ["story_id"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "story_gate_opened" } },
        "required": ["event"]
      },
      "then": { "required": ["story_id", "triggered_by"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "story_gate_resolved" } },
        "required": ["event"]
      },
      "then": { "required": ["story_id", "decision"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "plan_gate_opened" } },
        "required": ["event"]
      },
      "then": { "required": ["triggered_by"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "plan_gate_resolved" } },
        "required": ["event"]
      },
      "then": { "required": ["decision"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "review_gate_opened" } },
        "required": ["event"]
      },
      "then": { "required": ["triggered_by"] }
    },
    {
      "if": {
        "properties": { "event": { "const": "review_gate_resolved" } },
        "required": ["event"]
      },
      "then": { "required": ["decision"] }
    }
  ]
}
