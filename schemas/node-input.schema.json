{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woof.dev/schemas/node-input.schema.json",
  "title": "woof graph node input",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_type", "epic_id", "repo_root"],
  "properties": {
    "node_type": {
      "type": "string",
      "enum": [
        "discovery_research",
        "discovery_thinking",
        "discovery_brainstorm",
        "discovery_synthesis",
        "epic_definition",
        "breakdown_planning",
        "plan_critique",
        "plan_gate_open",
        "plan_gate_resolve",
        "executor_dispatch",
        "critique_dispatch",
        "review_disposition",
        "verification",
        "commit",
        "gate_open",
        "gate_resolve",
        "human_review"
      ]
    },
    "epic_id": {
      "type": "integer",
      "minimum": 1,
      "description": "Tracker-assigned epic identifier. Same value as E<N>."
    },
    "story_id": {
      "oneOf": [
        { "type": "string", "pattern": "^S[1-9]\\d*$" },
        { "type": "null" }
      ]
    },
    "repo_root": { "type": "string", "minLength": 1 },
    "reason": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "decision": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "approve",
            "revise_epic_contract",
            "revise_plan",
            "revise_story_scope",
            "split_story",
            "abandon_story",
            "abandon_epic",
            "keep_local",
            "accept_remote",
            "hand_merge"
          ]
        },
        { "type": "null" }
      ]
    }
  }
}
