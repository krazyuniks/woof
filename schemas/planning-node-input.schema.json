{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woof.dev/schemas/planning-node-input.schema.json",
  "title": "woof planning graph node input",
  "description": "Input contract for deterministic Stage 1-4 planning graph nodes. LLM nodes are pure producers: each node receives declared filesystem inputs and may write only the declared output paths. Artefact content remains validated by the dedicated discovery, epic, plan, critique, and gate schemas.",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_type", "epic_id", "repo_root", "epic_dir", "inputs"],
  "properties": {
    "node_type": {
      "$ref": "#/$defs/planning_node_type"
    },
    "epic_id": {
      "type": "integer",
      "minimum": 1,
      "description": "Tracker-assigned epic identifier. Same value as E<N>."
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "epic_dir": {
      "type": "string",
      "pattern": "^\\.woof/epics/E[1-9]\\d*$"
    },
    "inputs": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "node_type": { "const": "discovery_research" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/discovery_bucket_input" } }
      }
    },
    {
      "if": {
        "properties": { "node_type": { "const": "discovery_thinking" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/discovery_bucket_input" } }
      }
    },
    {
      "if": {
        "properties": { "node_type": { "const": "discovery_brainstorm" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/discovery_bucket_input" } }
      }
    },
    {
      "if": {
        "properties": { "node_type": { "const": "discovery_synthesis" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/discovery_synthesis_input" } }
      }
    },
    {
      "if": {
        "properties": { "node_type": { "const": "epic_definition" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/epic_definition_input" } }
      }
    },
    {
      "if": {
        "properties": { "node_type": { "const": "breakdown_planning" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/breakdown_planning_input" } }
      }
    },
    {
      "if": {
        "properties": { "node_type": { "const": "plan_critique" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/plan_critique_input" } }
      }
    },
    {
      "if": {
        "properties": { "node_type": { "const": "plan_gate_open" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/plan_gate_open_input" } }
      }
    },
    {
      "if": {
        "properties": { "node_type": { "const": "plan_gate_resolve" } },
        "required": ["node_type"]
      },
      "then": {
        "properties": { "inputs": { "$ref": "#/$defs/plan_gate_resolve_input" } }
      }
    }
  ],
  "$defs": {
    "planning_node_type": {
      "type": "string",
      "enum": [
        "discovery_research",
        "discovery_thinking",
        "discovery_brainstorm",
        "discovery_synthesis",
        "epic_definition",
        "breakdown_planning",
        "plan_critique",
        "plan_gate_open",
        "plan_gate_resolve"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "path_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/path" },
      "uniqueItems": true
    },
    "plan_gate_decision": {
      "type": "string",
      "enum": [
        "approve",
        "revise_epic_contract",
        "revise_plan",
        "abandon_epic",
        "keep_local",
        "accept_remote",
        "hand_merge"
      ]
    },
    "discovery_bucket_input": {
      "type": "object",
      "additionalProperties": false,
      "description": "Input for a Stage-1 producer bucket node (research, thinking, brainstorm). The producer reads the spark plus any prior-bucket source artefacts and writes one or more Markdown artefacts into bucket_dir. Building-block playbook text is appended to the producer prompt, not referenced by path.",
      "required": ["spark_path", "discovery_dir", "bucket_dir"],
      "properties": {
        "spark_path": { "$ref": "#/$defs/path" },
        "discovery_dir": { "$ref": "#/$defs/path" },
        "bucket_dir": { "$ref": "#/$defs/path" },
        "source_paths": { "$ref": "#/$defs/path_list" }
      }
    },
    "discovery_synthesis_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spark_path", "discovery_dir", "synthesis_dir"],
      "properties": {
        "spark_path": { "$ref": "#/$defs/path" },
        "discovery_dir": { "$ref": "#/$defs/path" },
        "synthesis_dir": { "$ref": "#/$defs/path" },
        "source_paths": { "$ref": "#/$defs/path_list" }
      }
    },
    "epic_definition_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["synthesis_dir", "epic_path"],
      "properties": {
        "synthesis_dir": { "$ref": "#/$defs/path" },
        "epic_path": { "$ref": "#/$defs/path" },
        "carried_open_questions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "breakdown_planning_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["epic_path", "plan_path", "plan_markdown_path"],
      "properties": {
        "epic_path": { "$ref": "#/$defs/path" },
        "plan_path": { "$ref": "#/$defs/path" },
        "plan_markdown_path": { "$ref": "#/$defs/path" }
      }
    },
    "plan_critique_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["epic_path", "plan_path", "plan_markdown_path", "critique_path"],
      "properties": {
        "epic_path": { "$ref": "#/$defs/path" },
        "plan_path": { "$ref": "#/$defs/path" },
        "plan_markdown_path": { "$ref": "#/$defs/path" },
        "critique_path": { "$ref": "#/$defs/path" }
      }
    },
    "plan_gate_open_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_path",
        "plan_markdown_path",
        "critique_path",
        "gate_path",
        "triggered_by"
      ],
      "properties": {
        "plan_path": { "$ref": "#/$defs/path" },
        "plan_markdown_path": { "$ref": "#/$defs/path" },
        "critique_path": { "$ref": "#/$defs/path" },
        "gate_path": {
          "type": "string",
          "pattern": "^\\.woof/epics/E[1-9]\\d*/gate\\.md$"
        },
        "triggered_by": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["plan_review", "schema_validation_failed", "manual"]
          }
        }
      }
    },
    "plan_gate_resolve_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_path", "decision"],
      "properties": {
        "gate_path": {
          "type": "string",
          "pattern": "^\\.woof/epics/E[1-9]\\d*/gate\\.md$"
        },
        "decision": { "$ref": "#/$defs/plan_gate_decision" },
        "revised_paths": { "$ref": "#/$defs/path_list" }
      }
    }
  }
}
