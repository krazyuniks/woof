{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woof.dev/schemas/planning-node-output.schema.json",
  "title": "woof planning graph node output",
  "description": "Planning-node view of the runtime node-output contract. Stage 1-4 graph nodes emit the same shape as schemas/node-output.schema.json, restricted to planning node types.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_type",
    "status",
    "epic_id",
    "work_unit_id",
    "next_node",
    "gate_path",
    "validation_summary",
    "triggered_by",
    "message",
    "paths"
  ],
  "properties": {
    "node_type": { "$ref": "#/$defs/planning_node_type" },
    "status": {
      "type": "string",
      "enum": ["completed", "gate_opened", "halted"]
    },
    "epic_id": {
      "type": "integer",
      "minimum": 1,
      "description": "Tracker-assigned epic identifier. Same value as E<N>."
    },
    "work_unit_id": {
      "type": "null"
    },
    "next_node": {
      "oneOf": [{ "$ref": "#/$defs/planning_node_type" }, { "type": "null" }]
    },
    "gate_path": {
      "oneOf": [
        { "type": "string", "pattern": "^\\.woof/epics/E[1-9]\\d*/gate\\.md$" },
        { "type": "null" }
      ]
    },
    "validation_summary": {
      "oneOf": [{ "$ref": "#/$defs/validation_summary" }, { "type": "null" }]
    },
    "triggered_by": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "message": {
      "type": "string"
    },
    "paths": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "gate_opened" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "gate_path": {
            "type": "string",
            "pattern": "^\\.woof/epics/E[1-9]\\d*/gate\\.md$"
          }
        }
      }
    }
  ],
  "$defs": {
    "planning_node_type": {
      "type": "string",
      "enum": [
        "discovery_research",
        "discovery_thinking",
        "discovery_ideate",
        "discovery_synthesis",
        "epic_definition",
        "breakdown_planning",
        "plan_critique",
        "plan_gate_open",
        "plan_gate_resolve"
      ]
    },
    "validation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "stage",
        "triggered_by",
        "check_count",
        "failed_check_count"
      ],
      "properties": {
        "ok": { "type": "boolean" },
        "stage": {
          "oneOf": [
            { "type": "integer", "enum": [1, 2, 3, 4] },
            { "type": "null" }
          ]
        },
        "triggered_by": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "check_count": { "type": "integer", "minimum": 0 },
        "failed_check_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
