{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woof.dev/schemas/policy.schema.json",
  "title": "woof repo policy",
  "description": "Project-side policy declaration at .woof/policy.toml. The policy selects the delivery profile, project verification command, producer/reviewer run profile slots, deterministic check floor, and cartography floor. Woof owns harness adapters, execution, parsing, validation, and graph transitions; consumer repositories own the policy values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "delivery",
    "profiles",
    "verification",
    "default_run_profile",
    "run_profiles",
    "checks",
    "cartography",
    "drain"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "repo_root", "toolchain_root", "base_branch"],
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["A", "B"],
          "description": "A = worktree plus pull request delivery; B = single-tree graph-owned commit and push."
        },
        "repo_root": {
          "$ref": "#/$defs/portable_path",
          "description": "Consumer repository root, relative to the policy file's repository root."
        },
        "toolchain_root": {
          "$ref": "#/$defs/portable_path",
          "description": "Directory where project verification commands run, relative to repo_root."
        },
        "base_branch": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "A": { "$ref": "#/$defs/profile_a" },
        "B": { "$ref": "#/$defs/profile_b" }
      },
      "minProperties": 1
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1,
          "description": "Project verification command run from delivery.toolchain_root."
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 600
        }
      }
    },
    "default_run_profile": {
      "type": "string",
      "minLength": 1
    },
    "run_profiles": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9_.-]+$"
      },
      "additionalProperties": { "$ref": "#/$defs/run_profile" },
      "minProperties": 1
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floor"],
      "properties": {
        "floor": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/check_id" },
          "description": "Deterministic checks required before graph-owned publish or commit."
        },
        "review_size": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_non_generated_changed_lines"],
          "properties": {
            "max_non_generated_changed_lines": {
              "type": "integer",
              "minimum": 1,
              "description": "Enable the review-size guard and open a review gate when staged non-generated changed lines exceed this threshold. Generated files are excluded from this count but reported explicitly."
            }
          }
        }
      }
    },
    "cartography": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floor"],
      "properties": {
        "floor": {
          "type": "string",
          "enum": ["none", "design", "lexical", "structural"],
          "description": "Minimum cartography floor preflight enforces and the graph may load."
        }
      }
    },
    "drain": {
      "$ref": "#/$defs/drain",
      "description": "Woof-native drain semantics shared by Woof and transitional consumers such as VaultForeman."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "delivery": {
            "properties": { "profile": { "const": "A" } },
            "required": ["profile"]
          }
        },
        "required": ["delivery"]
      },
      "then": {
        "properties": {
          "profiles": { "required": ["A"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delivery": {
            "properties": { "profile": { "const": "B" } },
            "required": ["profile"]
          }
        },
        "required": ["delivery"]
      },
      "then": {
        "properties": {
          "profiles": { "required": ["B"] }
        }
      }
    }
  ],
  "$defs": {
    "portable_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(?:/|[A-Za-z]:)"
      }
    },
    "profile_a": {
      "type": "object",
      "additionalProperties": false,
      "required": ["github_repo", "ready_label", "merge_path_groups", "worktree"],
      "properties": {
        "github_repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "ready_label": {
          "type": "string",
          "minLength": 1
        },
        "merge_path_groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_group" },
          "uniqueItems": true,
          "default": []
        },
        "terminal_deploy_checks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        },
        "mergeability_settle_timeout": {
          "type": "integer",
          "minimum": 1,
          "description": "Seconds to wait for GitHub mergeability and required-check recompute to settle after main moves, before the next Profile A merge."
        },
        "merge_attempts": {
          "type": "integer",
          "minimum": 1,
          "default": 5,
          "description": "Maximum squash-merge attempts for a Profile A PR when GitHub has not yet settled the just-pushed head for --match-head-commit."
        },
        "merge_interval_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 3.0,
          "description": "Seconds to wait between bounded squash-merge attempts after a transient --match-head-commit refusal."
        },
        "deploy_wait_timeout": {
          "type": "integer",
          "minimum": 1,
          "description": "Seconds to wait for the terminal deploy-check set to reach a terminal state between consecutive deploy-triggering merges."
        },
        "worktree": { "$ref": "#/$defs/worktree" }
      }
    },
    "profile_b": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "push"],
      "properties": {
        "commit": {
          "type": "boolean",
          "description": "Graph owns the commit transaction for ready work units."
        },
        "push": {
          "type": "boolean",
          "description": "Graph pushes the committed transaction to the selected branch."
        }
      }
    },
    "run_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "reviewer"],
      "properties": {
        "producer": { "$ref": "#/$defs/run_profile_slot" },
        "reviewer": { "$ref": "#/$defs/run_profile_slot" }
      }
    },
    "run_profile_slot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["harness"],
      "properties": {
        "harness": {
          "type": "string",
          "minLength": 1,
          "description": "Subscription CLI harness slot. The dispatch harness registry owns the accepted identifiers."
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "description": "Optional model override for this harness. When omitted, the dispatch harness registry supplies the harness default."
        },
        "effort": {
          "type": "string",
          "minLength": 1,
          "description": "Optional harness-specific reasoning effort override. When omitted, the dispatch harness registry supplies the harness default and validates supplied levels."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "check_id": {
      "type": "string",
      "enum": [
        "quality-gates",
        "outcome-markers",
        "scope",
        "contract-refs",
        "plan-crossrefs",
        "critique-blocker",
        "commit-transaction",
        "docs-drift",
        "review-valve"
      ]
    },
    "path_group": {
      "type": "string",
      "minLength": 1
    },
    "worktree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root"],
      "properties": {
        "root": {
          "$ref": "#/$defs/portable_path",
          "description": "Directory under which the consumer's per-run worktree provider places per-work-unit worktrees. Woof discovers and fail-closed-validates; it never provisions, mutates, destroys, or invokes that provider (ADR-015)."
        },
        "derivation": {
          "type": "string",
          "enum": ["unit_id", "manifest_map"],
          "default": "unit_id",
          "description": "Unit-to-path derivation: root plus work_unit_id, or an explicit per-unit map the task runner records in the run manifest when the per-run worktree provider owns path allocation."
        }
      }
    },
    "drain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "merge_after_ready_pr",
        "rerun_after_merge",
        "mark_unit_done_after_publish",
        "commit_backlog_state",
        "stop_when_no_eligible_units"
      ],
      "properties": {
        "merge_after_ready_pr": {
          "type": "boolean"
        },
        "rerun_after_merge": {
          "type": "boolean"
        },
        "mark_unit_done_after_publish": {
          "type": "boolean"
        },
        "commit_backlog_state": {
          "type": "boolean"
        },
        "stop_when_no_eligible_units": {
          "type": "boolean"
        }
      }
    }
  }
}
